# Copy this file to .env.local for local development, and set the
# same two values in Vercel (Project Settings -> Environment Variables)
# when you deploy.
#
# Both come from your Supabase project: Project Settings -> API.
# The anon key is safe to expose in the browser — it has no power on
# its own, the RLS policies in supabase/schema.sql are what actually
# decide who can read or write what.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
